{
  "name": "tether-monorepo",
  "version": "1.0.5",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:server": "bun --cwd apps/server dev",
    "dev:mobile": "bun --cwd apps/mobile start",
    "build:server": "bun --cwd apps/server build",
    "start:server": "bun --cwd apps/server start",
    "lint": "bun --cwd apps/server lint && bun --cwd apps/mobile lint",
    "format": "bun --cwd apps/server format"
  },
  "dependencies": {
    "bun-types": "^1.3.14"
  }
}
