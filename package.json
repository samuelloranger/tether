{
  "name": "tether-monorepo",
  "version": "1.15.1",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:server": "bun --cwd apps/server dev",
    "dev:mobile": "bun --cwd apps/mobile start",
    "build:server": "bun --cwd apps/server build",
    "start:server": "bun --cwd apps/server start",
    "lint": "bun --cwd apps/server lint && bun --cwd apps/server typecheck && bun --cwd apps/mobile typecheck",
    "format": "bun --cwd apps/server format",
    "docs:dev": "vitepress dev docs",
    "docs:build": "cp install.sh docs/public/install.sh && vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "dependencies": {
    "bun-types": "^1.3.14"
  },
  "devDependencies": {
    "typescript": "~7.0.2",
    "vitepress": "1.6.4"
  },
  "patchedDependencies": {
    "expo-modules-jsi@57.0.3": "patches/expo-modules-jsi@57.0.3.patch"
  }
}
