{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tether",
  "version": "1.1.0",
  "identifier": "cloud.samlo.tether",
  "build": {
    "frontendDist": "../dist",
    "beforeBuildCommand": "bun run build:web"
  },
  "app": {
    "windows": [
      {
        "title": "Tether",
        "width": 1000,
        "height": 720,
        "minWidth": 640,
        "minHeight": 480
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
