{
  "name": "tether",
  "version": "1.0.5",
  "private": true,
  "type": "module",
  "bin": {
    "tether": "./src/server/main.ts"
  },
  "scripts": {
    "dev": "bun run --watch src/server/index.ts",
    "build": "bun run build:binary",
    "start": "./dist/tether serve",
    "typecheck": "tsc --noEmit",
    "lint": "biome check",
    "format": "biome check --write",
    "build:binary": "bun build --compile --minify --define process.env.TETHER_VERSION=\\\"${TETHER_VERSION:-dev}\\\" --outfile dist/tether src/server/main.ts"
  },
  "dependencies": {
    "hono": "^4.7.4",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@types/bun": "latest",
    "typescript": "^7.0.2"
  }
}
