{
  "name": "tether",
  "version": "1.0.5",
  "private": true,
  "type": "module",
  "bin": {
    "tether": "./cli.ts"
  },
  "scripts": {
    "dev": "bun run --watch src/server/index.ts",
    "build": "bun build src/server/index.ts --outdir dist --target bun",
    "start": "bun run dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "biome check",
    "format": "biome check --write"
  },
  "dependencies": {
    "hono": "^4.7.4",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@types/bun": "latest",
    "typescript": "^5.8.2"
  }
}
