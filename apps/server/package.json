{
  "name": "tether",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/server/index.ts",
    "build": "bun run build:web && bun run build:server",
    "build:web": "cd src/web && bun run build",
    "build:server": "bun build src/server/index.ts --outdir dist --target bun",
    "start": "bun run dist/index.js",
    "typecheck": "tsc --noEmit && cd src/web && tsc --noEmit",
    "lint": "biome check",
    "format": "biome check --write"
  },
  "dependencies": {
    "hono": "^4.7.4",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@types/bun": "latest",
    "typescript": "^5.8.2"
  }
}
